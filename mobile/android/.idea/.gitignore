# OpenE2EE — mobile/android/.idea — Android Studio internal ignores
# Sprint 3 §9.
#
# Only team-shared project-level files are whitelisted (via root .gitignore):
#   - codeStyles/         (Kotlin / Java code style — team policy)
#   - inspectionProfiles/ (lint / inspection profile — team policy)
#   - runConfigurations/  (run / debug configurations — optional)
#   - .gitignore          (this file — explains the policy)
#
# Everything else inside .idea/ is user- or machine-specific and is ignored.

# User-specific window / session state
/shelf/
/workspace.xml
/tasks.xml
/usage.statistics.xml
/dictionaries/

# Auto-generated by Android Studio / Gradle sync
/caches/
/libraries/
/httpRequests/
/dataSources/
/dataSources.local.xml
/compiler.xml
/encodings.xml
/jarRepositories.xml
/mongo-express.xml
/markdown-navigator/
/navigation/
/assetWizardSettings.xml