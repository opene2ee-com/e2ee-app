# OpenE2EE — mobile/android/local.properties.example
# Sprint 3 §9 — dev override template.
#
# USAGE:
#   cp local.properties.example local.properties
#   # then edit the values for YOUR dev machine.
#
# NEVER commit local.properties — it is .gitignored at mobile/android/.gitignore
# AND at the repo-root .gitignore. It contains absolute paths to YOUR SDK /
# Flutter installation, which differ per dev machine.

# ─── Flutter SDK path (REQUIRED) ───────────────────────────────────
# `flutter doctor` auto-generates this. Override only if Flutter can't detect it.
# Examples:
#   Windows: flutter.sdk=C\:\\src\\flutter
#   macOS:   flutter.sdk=/Users/<you>/development/flutter
#   Linux:   flutter.sdk=/home/<you>/flutter
#
# Tip: run `flutter doctor -v` to see where Flutter thinks it lives.
flutter.sdk=

# ─── Android SDK path (REQUIRED) ───────────────────────────────────
# Same as above — `flutter doctor` auto-generates this. Manual override only
# if you installed the Android SDK in a non-default location.
# Examples:
#   Windows: sdk.dir=C\:\\Users\\<you>\\AppData\\Local\\Android\\Sdk
#   macOS:   sdk.dir=/Users/<you>/Library/Android/sdk
#   Linux:   sdk.dir=/home/<you>/Android/Sdk
#
# Tip: Android Studio → Settings → Appearance & Behavior → System Settings →
# Android SDK → the path is shown at the top.
sdk.dir=

# ─── NDK path (OPTIONAL) ───────────────────────────────────────────
# Only required if you build native (C / C++) modules. Flutter does NOT need
# the NDK for the default scaffold. Uncomment + set if a plugin you add
# requires it (e.g. SQLCipher, native crypto).
#
#   Windows: ndk.dir=C\:\\Users\\<you>\\AppData\\Local\\Android\\Sdk\\ndk\\26.1.10909125
#   macOS:   ndk.dir=/Users/<you>/Library/Android/sdk/ndk/26.1.10909125
#   Linux:   ndk.dir=/home/<you>/Android/Sdk/ndk/26.1.10909125
#
# ndk.dir=