<?xml version="1.0" encoding="UTF-8"?>
<!--
  mobile/ios/NetworkExtension/OpenE2eeTunnelProvider.entitlements

  PR-25 (Sprint 4) — Entitlements for the NetworkExtension (Packet Tunnel
  Provider) target. Separate from `Runner/Runner.entitlements` because
  Apple's Code Signing system requires each target to reference its own
  entitlements file via `CODE_SIGN_ENTITLEMENTS`. Sharing a single
  entitlements file across two targets is possible but makes per-target
  provisioning-profile management fragile — the canonical layout is one
  entitlements file per target.

  Required entries (per ADR-0003 risk A1):
    - `com.apple.developer.networking.networkextension` with value
      `packet-tunnel-provider` -> grants the right to subclass
      NEPacketTunnelProvider. Applied for from the developer portal.
    - `com.apple.developer.networking.vpn.api` with value `allow-vpn` ->
      grants the right to invoke `startVPNTunnel`. Applied for from the
      developer portal.
    - `com.apple.security.application-groups` for the App Group that the
      NetworkExtension target shares with the host app (Runner). The
      group id MUST match the one declared in Runner.entitlements so the
      tunnel can read the shared Keychain / UserDefaults blob for
      session hand-off.

  Sprint 7 Item 13 (MOB-6) addition:
    - `com.apple.developer.team-identifier` is REQUIRED for the App
      Group above. It MUST mirror the value in `Runner.entitlements`
      (both targets sign under the same Apple Developer Team). Sourced
      from `$(TEAMS_IDENTIFIER)` via `mobile/ios/Config/Local.xcconfig`
      or `mobile/ios/Config/Production.xcconfig`. See
      `docs/SETUP-iOS.md` for the substitution procedure.

  Privacy: we deliberately omit any entitlement related to device
  identifiers (`com.apple.developer.device-information`) or location —
  per ADR-0006 these are forbidden.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.developer.team-identifier</key>
    <array>
        <string>$(TEAMS_IDENTIFIER)</string>
    </array>
    <key>com.apple.developer.networking.networkextension</key>
    <array>
        <string>packet-tunnel-provider</string>
    </array>
    <key>com.apple.developer.networking.vpn.api</key>
    <array>
        <string>allow-vpn</string>
    </array>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.opene2ee.opene2ee</string>
    </array>
</dict>
</plist>