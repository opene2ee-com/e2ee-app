<?xml version="1.0" encoding="UTF-8"?>
<!--
  mobile/ios/Runner/Info.plist

  PR-22b (Sprint 3) — Info.plist for the OpenE2EE iOS Runner target.

  Key entries
  -----------
  - `NSVPNUsageDescription` (required by Apple for any App or
    NetworkExtension bundle that uses the Personal VPN framework): we
    surface a fixed privacy-preserving description. Any future change
    requires an ADR amendment (ADR-0003 risk A1).

  - `UIBackgroundModes` includes `vpn` so the NetworkExtension target
    can keep the tunnel alive while the host app is in the background.

  - `LSApplicationCategoryType` is `public.app-category.utilities`.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>OpenE2EE</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>opene2ee</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>

    <!--
      Apple Privacy Manifest placeholder. The real PrivacyInfo.xcprivacy
      is added in Sprint 4 alongside the `NSPrivacyAccessedAPITypes`
      declarations required by WWDC 2023.
    -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
    <key>NSPrivacyTracking</key>
    <false/>

    <!--
      Personal VPN usage description — required by Apple for any app that
      uses NetworkExtension / Personal VPN APIs. The wording is fixed by
      this brief; any future change requires an ADR amendment.
    -->
    <key>NSVPNUsageDescription</key>
    <string>OpenE2EE performs network diagnostics to evaluate encryption quality on your device. No content is read.</string>

    <!--
      Sprint 7 Item 15 / MOB-10 — Biometric prompt (FaceID) usage
      description.

      REQUIRED by Apple for any app that calls
      `LAContext.canEvaluatePolicy(.deviceOwnerAuthenticationWithBiometrics)`
      or invokes FaceID via the `LocalAuthentication` framework. Without
      this key, the FIRST biometric prompt crashes the app with the
      fatal `NSFaceIDUsageDescription missing` error from
      `LAContext.canEvaluatePolicy`.

      Privacy contract (enforced by `mobile/test/mobile/security/
      biometric_posture_test.dart`):
        * The string is reviewed by cyber-security on every change.
        * No UUID, hex fingerprint, e-mail, phone number, or PII keyword
          may appear here — the FaceID overlay shows this string
          verbatim and a shoulder-surfer / compromised screen-recorder
          could otherwise capture an identifier.
        * No mention of passcode / PIN / pattern — that would imply a
          non-biometric fallback, defeating the MOB-10 hardening.
        * The wording is generic, future-proof, and ADR-0006 compliant.
    -->
    <key>NSFaceIDUsageDescription</key>
    <string>OpenE2EE uses Face ID to confirm sensitive on-device operations such as erasing the anonymous device identity.</string>

    <!--
      Allow the Personal VPN to stay alive while the host app is in the
      background. The NetworkExtension target's lifecycle drives the
      actual packet loop.
    -->
    <key>UIBackgroundModes</key>
    <array>
        <string>vpn</string>
    </array>

    <!--
      Minimum iOS version. PR-29 (Sprint 5) bumps the deployment target from
      14.0 to 15.0. PR-22b / PR-25 had to keep iOS 14 as the floor because
      `NEAppRules.includeAppRules` is iOS 14+ but `excludeAppRules` (the
      canonical deny-list path) is iOS 15+; the previous Sprint kept an
      `#available(iOS 15.0, *)` guard and an iOS-14 fallback that logged a
      breadcrumb while continuing to cover all apps (PR-29 §C removes that
      fallback now that the deployment target is iOS 15+ across all
      targets). Per-app VPN is fully supported on iOS 15+, Apple CryptoKit
      HKDF + AES.GCM invariants are unchanged, and Keychain access groups
      work as designed (Runner.entitlements declares
      `group.com.opene2ee.opene2ee`).
    -->
    <key>MinimumOSVersion</key>
    <string>15.0</string>

    <!--
      Standard Flutter launch screen — retained for the Runner target.
    -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!--
      MOB-8 (Sprint 7) — TLS certificate pinning (defence-in-depth).

      NSAppTransportSecurity / NSPinnedDomains pins the production
      `api.opene2ee.com` and `staging.opene2ee.com` leaf-certificate
      SHA-256 digests (base-64 in `<data>` blocks). The override below is
      evaluated at every TLS handshake — TLS only succeeds when the
      server cert's SPKI matches one of the listed entries.

      Two distinct pins per host:
        - Primary:  current production CA SPKI SHA-256 (base-64).
        - Backup:   secondary CA / cross-signed SPKI SHA-256 (base-64).

      Failure mode: if NO listed pin matches, the TLS handshake is
      refused and the app cannot reach the backend. This is the intended
      "fail-closed" stance (cite OWASP MASVS-NETWORK-1 + cyber-security
      Sprint 7 review, finding MOB-8).

      Rotation procedure: see docs/SPRINT-7-MOB-8-CERT-PINNING.md.
      Summary:
        1. Replace the placeholder BASE64 strings below with the actual
           SPKI SHA-256 hashes of the production CA(s) currently serving
           api.opene2ee.com + staging.opene2ee.com.
           `openssl s_client -connect api.opene2ee.com:443 -servername api.opene2ee.com < /dev/null \
              | openssl x509 -noout -pubkey \
              | openssl asn1parse -noout -inform PEM -out - SPKI \
              | openssl dgst -sha256 -binary \
              | base64`
        2. Ship to clients with BOTH production + backup pins present.
        3. After expiry (or after the old CA is decommissioned), drop
           the old pin.
        4. Re-run `flutter test` — the cert_pinning_posture_test must
           still pass (the test asserts >=2 <data> entries per domain
           and an un-commented pin-set in network_security_config.xml).

      Defence-in-depth layers:
        Layer 1 — HTTPS-only (NSAppTransportSecurity default, no
                  `NSAllowsArbitraryLoads`).
        Layer 2 — System trust anchors only (no NSExceptionDomains that
                  widen trust to user-installed CAs).
        Layer 3 — THIS block (NSPinnedDomains + backup pin).
        Layer 4 — Dart-side `PinnedHttpOverrides` in
                  `lib/shared/cert_pinning.dart`, installed via
                  `PinnedHttpOverrides.installGlobal(...)` at boot.

      Before this block was committed: only layers 1 + 2 were enforced,
      and the Android-side pin-set was kept as a commented placeholder.
      MOB-8 promotes the placeholder into a real pin-set so all three
      platforms share the same posture.

      References:
        - https://developer.apple.com/documentation/bundleresources/information_property_list/nsapptransportsecurity
        - https://developer.apple.com/documentation/bundleresources/information_property_list/nsapptransportsecurity/nspinneddomains
        - OWASP MASVS-NETWORK-1
        - cyber-security Sprint 7 review (MOB-8, High — 2026-07-07)
        - docs/SPRINT-7-MOB-8-CERT-PINNING.md
        - mobile/android/app/src/main/res/xml/network_security_config.xml
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSPinnedDomains</key>
        <dict>

            <!--
              api.opene2ee.com (production).

              NSPinnedLeafIdentities expects each <data> entry to be the
              base-64 SHA-256 of the leaf certificate's
              SubjectPublicKeyInfo (SPKI). Both pins must be
              simultaneously present during a rotation window so a TLS
              handshake that presents the new CA is still accepted.
            -->
            <key>api.opene2ee.com</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSPinnedLeafIdentities</key>
                <array>
                    <!--
                      Primary SPKI SHA-256 (base-64). REPLACE before
                      public launch — operator-side rotation only.
                      See rotation procedure in docs/SPRINT-7-MOB-8-CERT-PINNING.md.
                    -->
                    <data>PLACEHOLDER_PRODUCTION_CA_SPKI_SHA256_BASE64==</data>
                    <!--
                      Backup SPKI SHA-256 (base-64). Cross-signed /
                      secondary CA kept in the list so a CA change
                      does not require an app update.
                    -->
                    <data>PLACEHOLDER_BACKUP_CA_SPKI_SHA256_BASE64==</data>
                </array>
            </dict>

            <!--
              staging.opene2ee.com (CI / preprod).

              Pinned to the same primary + backup SPKIs as production
              so a CA change requires only one rotation rather than
              per-environment edits.
            -->
            <key>staging.opene2ee.com</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSPinnedLeafIdentities</key>
                <array>
                    <data>PLACEHOLDER_PRODUCTION_CA_SPKI_SHA256_BASE64==</data>
                    <data>PLACEHOLDER_BACKUP_CA_SPKI_SHA256_BASE64==</data>
                </array>
            </dict>

        </dict>
    </dict>
</dict>
</plist>
