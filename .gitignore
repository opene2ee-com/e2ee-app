# OpenE2EE monorepo — Multi-OS + multi-editor artifacts
# ADR-0008 §2.3 — Sprint 2 PR-MP-3
# OS-agnostic kalıp korunmuş + multi-OS/editor/Flutter/Go artifact'ları eklenmiş.

# ─────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
._*
.fseventsd

# ─────────────────────────────────────────────────────────────
# Windows
# ─────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.url
[Dd]esktop.ini

# ─────────────────────────────────────────────────────────────
# Linux / KDE / GNOME
# ─────────────────────────────────────────────────────────────
.directory
.fuse_hidden*
.Trash-*
.nfs*

# ─────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────
# Visual Studio (NOT VSCode — farklı araç, farklı klasör)
.vs/

# VSCode — ignore everything except team-tracked config (PR-MP-6)
# Syntax: .vscode/* matches files inside; negation re-includes specific files.
# .vscode/ (directory-only) yerine .vscode/* kullanıldı → negation semantics reliable
# (deeper dirs'da bile: matched files are explicitly re-included).
# user-specific auto-generated dosyalar (argv.json, .browse.VC.db, vb.) ignored kalır.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# IntelliJ / GoLand / Android Studio
# Sprint 3 §9 — Native dev tooling:
# Whitelist team-shared project-level Android Studio files (mobile/android/.idea/).
# Pattern: negate only the team-shared subdirs/files inside .idea/.
# User-specific files (workspace.xml, tasks.xml, caches/, etc.) remain ignored.
.idea/
*.iml
*.ipr
*.iws
out/

# Whitelisted Android Studio project-level files (Sprint 3 §9)
# Scoped to mobile/android/ so backend GoLand .idea/ stays ignored.
# Note: gitignore can't re-include a file if its parent directory is excluded,
# so we must first re-include the parent .idea/ dir, then the subdirs / files.
!mobile/android/.idea/
!mobile/android/.idea/codeStyles/
!mobile/android/.idea/inspectionProfiles/
!mobile/android/.idea/runConfigurations/
!mobile/android/.idea/.gitignore

# Eclipse
.bundle/
.project
.classpath
.settings/

# Vim / Emacs / Nano
*.swp
*.swo
*~
.\#*
\#*\#
.emacs.desktop
.sticky.el

# Sublime Text
*.sublime-project
*.sublime-workspace

