# ============================================================================
# OpenE2EE — Environment Variables (ÖRNEK)
# ----------------------------------------------------------------------------
# Bu dosya repoda paylaşılır; gerçek değerler YOK.
# Kullanım:
#   cp infra/.env.example infra/.env
#   nano infra/.env   # secret'ları set et
#   docker compose -f infra/docker-compose.yml --env-file infra/.env up -d
#
# .gitignore zaten .env'i ignore eder (.env.example hariç).
#
# Üretimde (DEPLOYMENT.md §6) bu dosya VPS'te yaşar, Git'e commit edilmez.
# Sprint 2'de HashiCorp Vault veya sops+age ile Git-encrypted secret yönetimi.
#
# Gizli değer üretme (her secret için ayrı):
#   openssl rand -hex 32
# ============================================================================

# ----------------------------------------------------------------------------
# Genel — compose & ortak
# ----------------------------------------------------------------------------
# Domain (prod: opene2ee.com; dev: opene2ee.local)
DOMAIN=opene2ee.local
ADMIN_EMAIL=admin@opene2ee.local
COMPOSE_PROJECT_NAME=opene2ee
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# PostgreSQL (TimescaleDB image — internal network)
# ----------------------------------------------------------------------------
POSTGRES_DB=opene2ee
POSTGRES_USER=opene2ee
# DEV default (compose dosyasında override edilir); prod için değiştir:
POSTGRES_PASSWORD=__SET_ME_postgres_password_change_in_prod__
# Host port (dev için açık; prod'da kaldırılacak)
POSTGRES_HOST_PORT=5432

# ----------------------------------------------------------------------------
# Redis (internal network, Active Pool + cache)
# ----------------------------------------------------------------------------
REDIS_HOST_PORT=6379
REDIS_MAXMEMORY=256mb
# Dev ortamında şifresiz; prod'da mutlaka set et:
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# Backend (Go) — env contract: backend/cmd/server/main.go (PR-8)
# ----------------------------------------------------------------------------
SERVER_PORT=8080
# SERVER_SALT — UUID v7 hash için salt (ADR-0006), yıllık rotate önerilir.
# Minimum 32 hex char; openssl rand -hex 32 ile üret:
SERVER_SALT=__SET_ME_server_salt_min_32_hex_chars__
# JWT_SECRET — Sprint 5 PR-32 (ADV-3). HS256 shared secret used by
# the backend (auth.IssueJWT on POST /api/v1/auth + IsAuthorized
# middleware) AND by Kong's JWT plugin (referenced via the env vault
# {vault://env/jwt-secret} in infra/kong/kong.yml).
# Minimum 32 bytes; openssl rand -hex 32 ile üret. The backend
# fails closed when JWT_SECRET is empty (login returns 500, protected
# routes 401).
JWT_SECRET=__SET_ME_jwt_secret_min_32_bytes_change_in_prod__
SHUTDOWN_TIMEOUT_SEC=30
HEALTHCHECK_TIMEOUT_MS=2000

# ----------------------------------------------------------------------------
# Kong Gateway (external network)
# ----------------------------------------------------------------------------
# HTTP / HTTPS proxy portları (host'tan erişim)
KONG_PROXY_HTTP_PORT=8000
KONG_PROXY_HTTPS_PORT=8443
# Admin API — DEV: açık; PROD: internal-only (8001'i host'a expose etme)
KONG_ADMIN_PORT=8001
KONG_LOG_LEVEL=info
# Kong declarative config path (container içinde)
KONG_DECLARATIVE_CONFIG=/etc/kong/kong.yml

# ----------------------------------------------------------------------------
# Nginx (alternatif reverse proxy — sadece --profile nginx ile)
# ----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ----------------------------------------------------------------------------
# Coturn TURN/STUN (external, public UDP/TCP bypass)
# ----------------------------------------------------------------------------
# COTURN_PUBLIC_IP — host'un dış IP'si (NAT arkasında bu gerekli).
# Dev'de 127.0.0.1 bırakılabilir; prod'da VPS public IP'si.
COTURN_PUBLIC_IP=127.0.0.1
COTURN_LISTEN_PORT=3478
COTURN_MIN_PORT=49152
COTURN_MAX_PORT=65535
COTURN_REALM=opene2ee.local
# COTURN_STATIC_SECRET — TURN REST API time-limited credential üretmek için.
# openssl rand -hex 32 ile üret; rotate edilebilir.
COTURN_STATIC_SECRET=__SET_ME_coturn_static_secret_change_in_prod__

# ----------------------------------------------------------------------------
# Coturn TLS / DTLS — Üretim (Sprint 7 SCA-22)
# ----------------------------------------------------------------------------
# COTURN_TLS_ENABLED — TLS+DTLS gate (false=dev, true=prod).
# Dev'de unset/false → --no-tls --no-dtls (sertifikasız çalışır).
# Prod'da "true" → Let's Encrypt veya internal CA cert'i okur, --tls --dtls
# ile 5349/tcp + 5349/udp portlarını açar. Sertifika yoksa container
# fail-closed (exit 1) — sessizce plain moda düşmez.
COTURN_TLS_ENABLED=false
# COTURN_TLS_PORT — TURN-over-TLS (RFC 6062) + TURN-over-DTLS portu.
# Prod'da mobile client turns://turn.opene2ee.com:${COTURN_TLS_PORT} kullanır.
COTURN_TLS_PORT=5349
# COTURN_TLS_DOMAIN — cert subject CN / SAN'ı (certbot live dizini ile aynı).
# Prod varsayılan: opene2ee.com (DOMAIN ile aynı).
# COTURN_TLS_DOMAIN=opene2ee.com
# COTURN_TLS_CERTDIR — container içi cert kök dizini (compose volume mount).
# Default certbot_data volume mount noktası; değiştirme.
COTURN_TLS_CERTDIR=/etc/coturn/certs

# ----------------------------------------------------------------------------
# Certbot (Let's Encrypt — production only)
# ----------------------------------------------------------------------------
# Dev ortamında TLS gerekmez (HTTP-only test). Prod'da:
#   docker compose run --rm certbot certonly --webroot \
#     --webroot-path=/var/www/certbot \
#     --email $ADMIN_EMAIL --agree-tos --no-eff-email \
#     -d $DOMAIN -d www.$DOMAIN
CERTBOT_IMAGE=certbot/certbot:latest

# ----------------------------------------------------------------------------
# Feature flags (opsiyonel)
# ----------------------------------------------------------------------------
# Telemetri imzalama (F9 — opsiyonel):
ENABLE_TELEMETRY_SIGNING=false
# Echo-Bot aktif (PR-5):
ENABLE_ECHO_BOT=true
# Detached mode (detach Ctrl+P / Ctrl+Q):
COMPOSE_DETACHED=true